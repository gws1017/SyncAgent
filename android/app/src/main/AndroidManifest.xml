<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 백그라운드에서 계속 돌기 위한 포그라운드 서비스 권한 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- 이벤트 알림 표시 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="Sync Agent"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:hasCode="true">

        <activity
            android:name="com.syncagent.MainActivity"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="true">
            <!-- 로드할 .so 이름 — CMakeLists의 add_library 이름과 일치 -->
            <meta-data android:name="android.app.lib_name"
                android:value="syncagent" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="com.syncagent.SyncService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

    </application>

</manifest>
